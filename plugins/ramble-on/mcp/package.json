{
  "name": "ramble-on-mcp",
  "version": "1.2.0",
  "private": true,
  "description": "Bundled MCP server for the ramble-on plugin (stdio + HTTP transports).",
  "scripts": {
    "mcp:stdio": "node bin/stdio.cjs",
    "mcp:http": "node bin/http.cjs",
    "build": "esbuild bin/stdio.cjs --bundle --platform=node --format=cjs --outfile=dist/stdio.bundle.cjs && esbuild bin/http.cjs --bundle --platform=node --format=cjs --outfile=dist/http.bundle.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
